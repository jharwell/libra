@startuml
title LIBRA Architecture: Configure-Time vs. Build-Time

' Style Settings
!theme cerulean-outline
skinparam componentStyle rectangle
skinparam DefaultFontSize 14
skinparam defaultTextAlignment center
skinparam TitleFontSize 24
skinparam SequenceMessageAlignment center
skinparam DefaultFontColor #black
skinparam TitleFontColor #black
skinparam ParticipantFontColor #black

skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam nodesep 50
skinparam ranksep 50

' Style Settings
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false
skinparam nodesep 20
skinparam ranksep 40

' This "invisible" group forces the internal packages to respect the same vertical axis
node "LIBRA Flow" as Flow #transparent;line:transparent {

    package "Configure-Time (CMake Phase)" as ConfigPhase {
        component "Your CMakeLists.txt" as CMake
        component "find_package(libra)" as FindPkg
        component "LIBRA Core" as Core
        component "project-local.cmake" as Local

        package "Logic & Discovery" {
            component "Compiler Config\n(GCC, Clang, MSVC)" as CompilerCfg
            component "Target Discovery" as TargetCfg
            component "Test Registration\n(GTest, Catch2)" as TestCfg
            component "Tool Registration\n(Clang-Tidy, Doxygen)" as ToolCfg
        }

        CMake -> FindPkg
        FindPkg -> Core
        Core <-> Local
        Core --> CompilerCfg
        Core --> TargetCfg
        Core --> TestCfg
        Core --> ToolCfg
    }

    ' The "Center Spine" connector
    ConfigPhase -[hidden]down- BuildPhase

    package "Build-Time (Generator Phase)" as BuildPhase {
        component "Standard CMake Generators\n(Makefiles, Ninja, etc.)" as Gen

        package "Generated Targets" {
            component "Build Binary\n(.exe, .so)" as Build
            component "Test Suite\n(CTest)" as Test
            component "Static Analysis\n(Clang-Tidy)" as Analyze
            component "Documentation\n(Doxygen)" as Docs
            component "Coverage\n(LCOV)" as Coverage
        }

        Build -down-> Gen
        Test -down-> Gen
        Analyze -down-> Gen
        Coverage -down-> Gen
        Docs -down-> Gen
    }
}

' Cross-Phase Relationships (using the 'thickness' of 4 dashes to keep it vertical)
CompilerCfg ....> Build
TargetCfg ....> Build
TestCfg ....> Test
ToolCfg ....> Analyze
ToolCfg ....> Docs
ToolCfg ....> Coverage

@enduml
